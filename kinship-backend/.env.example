# Server
PORT=6050
NODE_ENV=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/database?sslmode=disable

# Auth
JWT_SECRET=

# Encryption (must match mmosh-app values)
ENCRYPTION_METHOD=aes-256-cbc
SECRET_KEY=
SECRET_IV=

# AI
ANTHROPIC_KEY=
OPEN_AI_KEY=
AI_API_BASE=

# Apple App Store
APPLE_APP_STORE_BUNDLE_ID=
APPLE_APP_STORE_ISSUER=
APPLE_APP_STORE_SANDBOX=true
APPLE_APP_STORE_APP_ID=
APPLE_APP_STORE_SERVER_PRIVATE_KEY=
APPLE_APP_STORE_SERVER_KEY_ID=
APPLE_APP_STORE_CONNECT_PRIVATE_KEY=
APPLE_APP_STORE_CONNECT_KEY_ID=

# Google Billing
GOOGLE_BILLING_PUBSUB_SUBSCRIPTION=
GOOGLE_BILLING_PUBSUB_VERIFICATION_TOKEN=
GOOGLE_APP_STORE_BUNDLE_ID=

# Stripe
STRIPE_KEY=

# Kartra
KARTRA_APP_ID=
KARTRA_API_KEY=
KARTRA_API_PASSWORD=
KARTRA_API_BASE=https://app.kartra.com/api

# Email
SENDGRID_API_KEY=

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Wallet service
WALLET_BACKEND_URL=http://localhost:3001

# Frontend
NEXT_BACKEND_URL=http://localhost:3000
