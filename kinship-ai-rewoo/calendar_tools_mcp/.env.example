# MongoDB configuration
MONGO_URI=mongodb://localhost:27017?retryWrites=true&w=majority
MONGO_DB_NAME=live_forge

# Google OAuth configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PostgreSQL configuration (DATABASE_URL format)
# Format: postgresql://username:password@host:port/database
# Note: Special characters in password must be URL-encoded (e.g., @ = %40)
DATABASE_URL=postgresql://postgres:password@localhost:5432/kinship_agent

# Encryption key for tool_connections credentials
# This should match the encryption key used in kinship-agent
ENCRYPTION_SECRET_KEY=your-encryption-secret-key-here

# Server configuration
HOST=0.0.0.0
PORT=8002
# LOG_LEVEL=info
