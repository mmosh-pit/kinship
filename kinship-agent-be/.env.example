# Kinship Agent Configuration
# ============================================

# Application Settings
APP_NAME="Kinship Agent"
APP_ENV=development
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration (PostgreSQL)
# Note: Use postgresql:// or postgresql+asyncpg:// - both work (auto-converted)
DATABASE_URL=postgresql://postgres:password@localhost:5432/kinship_agent

# LLM Provider Configuration
# Supported: openai, anthropic, gemini
LLM_PROVIDER=openai

# OpenAI Configuration (ChatGPT)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Anthropic Configuration (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Configuration (Gemini)
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-3.1-pro-preview-customtools

# LangSmith Configuration (optional but recommended)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=kinship-agent

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Knowledge Base Configuration
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Pinecone Vector Database
# Get your API key from https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=your-index-name
PINECONE_NAMESPACE=default

# Voyage AI Embeddings (recommended)
# Get your API key from https://www.voyageai.com
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-3-lite

# OpenAI Embeddings (fallback if Voyage not configured)
# Uses the OPENAI_API_KEY from above
EMBEDDING_MODEL=text-embedding-3-small

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
