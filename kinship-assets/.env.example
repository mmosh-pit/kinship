# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kinship_assets
DB_USER=kinship
DB_PASSWORD=your_password_here

# Google Cloud Storage
GCS_BUCKET_NAME=kinship-assets-poc
GCS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./kinship-assets-sa-key.json
GCS_BASE_URL=https://storage.googleapis.com/kinship-assets-poc

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Upload limits
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=image/png,image/jpeg,image/webp,audio/mpeg,audio/wav,application/json,application/xml

# Thumbnail generation
THUMBNAIL_WIDTH=200
THUMBNAIL_HEIGHT=200
